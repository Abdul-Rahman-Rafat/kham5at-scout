{
  "manifest_version": 3,
  "name": "Kham5at Scout",
  "version": "1.0.0",
  "description": "Automatically load, filter, and search Khamsat community requests.",

  "permissions": ["activeTab", "scripting", "storage"],

  "host_permissions": ["https://khamsat.com/*"],

  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Kham5at Scout",
    "default_icon": {
      "16": "icons/icon2.png",
      "32": "icons/icon2.png",
      "48": "icons/icon2.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://khamsat.com/community/requests*"],
      "js": ["content.js"]
    }
  ]
}
